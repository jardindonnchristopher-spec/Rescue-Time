rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Phase 3: Primitive Definitions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isSignedIn() && request.auth.uid == resource.data.uid;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    // --- Phase 4: Validation Blueprints (The "Anti-Update-Gap") ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email'])
        && data.uid == request.auth.uid
        && data.email is string && data.email.size() <= 256
        && (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 128))
        && (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 512));
    }

    function isValidAppSettings(data) {
      return data.keys().hasAll(['uid'])
        && data.uid == request.auth.uid
        && (!('theme' in data) || data.theme in ['light', 'dark'])
        && (!('schoolWorkColor' in data) || (data.schoolWorkColor is string && data.schoolWorkColor.size() <= 20))
        && (!('personalTaskColor' in data) || (data.personalTaskColor is string && data.personalTaskColor.size() <= 20));
    }

    function isValidDay(data) {
      return data.keys().hasAll(['uid', 'date', 'content'])
        && data.uid == request.auth.uid
        && data.date is string && data.date.size() <= 20
        && data.content is string && data.content.size() <= 5000;
    }

    function isValidTask(data) {
      return data.keys().hasAll(['uid', 'text', 'completed'])
        && data.uid == request.auth.uid
        && data.text is string && data.text.size() > 0 && data.text.size() <= 1000
        && data.completed is bool
        && (!('category' in data) || data.category in ['SCHOOL WORK', 'PERSONAL TASK'])
        && (!('priority' in data) || data.priority in ['low', 'medium', 'high'])
        && (!('startTime' in data) || data.startTime == null || data.startTime is timestamp)
        && (!('dueTime' in data) || data.dueTime == null || data.dueTime is timestamp);
    }

    // --- Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time
        && incoming().keys().size() <= 7;
      allow update: if isOwner(userId) && isValidUser(incoming())
        && incoming().uid == existing().uid
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && incoming().diff(existing()).affectedKeys().hasOnly(['email', 'displayName', 'photoURL', 'updatedAt']);
    }

    match /settings/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidAppSettings(incoming())
        && incoming().updatedAt == request.time
        && incoming().keys().size() <= 6;
      allow update: if isOwner(userId) && isValidAppSettings(incoming())
        && incoming().uid == existing().uid
        && incoming().updatedAt == request.time
        && incoming().diff(existing()).affectedKeys().hasOnly(['theme', 'schoolWorkColor', 'personalTaskColor', 'updatedAt']);
    }

    match /days/{dayId} {
      allow get: if isDocOwner();
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isVerified() && isValidId(dayId) && isValidDay(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time
        && incoming().keys().size() <= 6;
      allow update: if isDocOwner() && isValidDay(incoming())
        && incoming().uid == existing().uid
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && incoming().diff(existing()).affectedKeys().hasOnly(['content', 'date', 'updatedAt']);
      allow delete: if isDocOwner();
    }

    match /tasks/{taskId} {
      allow get: if isDocOwner();
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isVerified() && isValidId(taskId) && isValidTask(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time
        && incoming().keys().size() <= 11;
      allow update: if isDocOwner() && isValidTask(incoming())
        && incoming().uid == existing().uid
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && (
          // Action: Toggle completion
          incoming().diff(existing()).affectedKeys().hasOnly(['completed', 'updatedAt']) ||
          // Action: Edit details
          incoming().diff(existing()).affectedKeys().hasOnly(['text', 'startTime', 'dueTime', 'category', 'priority', 'updatedAt'])
        );
      allow delete: if isDocOwner();
    }
  }
}
